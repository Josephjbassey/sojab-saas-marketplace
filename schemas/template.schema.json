{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SaaSTemplate",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "slug": { "type": "string" },
    "category": { "type": "string" },
    "description": { "type": "string" },
    "stack": {
      "type": "object",
      "properties": {
        "backend": { "type": "string" },
        "frontend": { "type": "string" },
        "database": { "type": "string" }
      }
    },
    "features": {
      "type": "array",
      "items": { "type": "string" }
    },
    "configuration_options": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supported_payment_providers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supported_deployment_targets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cms_enabled": { "type": "boolean" },
    "version": { "type": "string" },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "changes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "license_type": { "enum": ["personal", "commercial", "agency"] },
    "documentation_paths": {
      "type": "object",
      "properties": {
        "getting_started": { "type": "string" },
        "deployment": { "type": "string" }
      }
    }
  },
  "required": ["name", "slug", "version", "license_type"]
}
